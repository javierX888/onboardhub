# =====================================================
# OnBoardHub - Variables de Entorno
# =====================================================
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env  (Linux/Mac)
#   Copy-Item .env.example .env  (Windows PowerShell)
# =====================================================

# Base de Datos PostgreSQL
# Formato: postgresql+asyncpg://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/onboardhub
